# RealEstork — Environment Variables Template
# Copy to .env and fill in your values

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Use service role key (not anon key) for backend operations

# === Zalo OA (for vợ's alerts) ===
ZALO_OA_ACCESS_TOKEN=your-zalo-oa-access-token
ZALO_WIFE_USER_ID=your-wife-zalo-user-id
# Get from: https://developers.zalo.me/app/your-app/oa

# === Telegram Bot (for aggregate product) ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id       # Chat ID cá nhân của bạn
TELEGRAM_GROUP_CHAT_ID=your-group-chat-id       # Group ID cho vợ chồng cùng xem
# Get from @BotFather on Telegram

# === AI API Keys (optional, for Tier 3) ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# === openclaw-zero-token (Tier 1 AI, local) ===
OPENCLAW_BASE_URL=http://localhost:3001/v1
OPENCLAW_API_KEY=any-string-works

# === Ollama (Tier 4, local GPU) ===
OLLAMA_BASE_URL=http://localhost:11434

# === Proxy (optional, add when blocked) ===
WEBSHARE_PROXY_URL=http://user:pass@proxy.webshare.io:80
# Leave empty to use direct IP

# === Discord (for aggregate product community) ===
DISCORD_BOT_TOKEN=your-discord-bot-token

# === Google Search (optional, for OSINT) ===
SERPAPI_KEY=your-serpapi-key-here
# Free tier: 100 searches/month — enough for MVP

# === Nhatot phone reveal ===
NHATOT_ACCESS_TOKEN=
# Token tự động refresh qua Google OAuth (không cần nhập tay).
# Setup lần đầu: python -m cli.main setup-nhatot
# Browser profile lưu tại .nhatot_browser_profile/ (gitignored)

# === Batdongsan phone reveal ===
BDS_ACCOUNT_PHONE=
# SĐT của tài khoản batdongsan dùng để DecryptPhone (tùy chọn).
# Ví dụ: BDS_ACCOUNT_PHONE=0901234567
# Setup lần đầu: python -m cli.main setup-batdongsan
# Cookies (~7 ngày TTL) lưu tại .batdongsan_cookies.json (gitignored)
# Không thể auto-refresh (cần OTP thủ công) → Telegram sẽ nhắc trước 24h

# === App settings ===
LOG_LEVEL=INFO
LOG_FILE=logs/realestork.log
DRY_RUN=false
# DRY_RUN=true → scrape + classify but don't send alerts (for testing)
